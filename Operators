public class OperatorsExample {
    public static void main(String[] args) {

        int a = 10, b = 5;

        // Arithmetic
        System.out.println("Addition: " + (a + b));
        System.out.println("Subtraction: " + (a - b));

        // Relational
        System.out.println(a > b);  // true

        // Logical
        System.out.println(a > 5 && b < 10); // true
    }
}
